# app1 (Notebook · Spring + React, group-a) backend 환경 변수
# 사용: cp .env.example .env 후 값 채우기

# ── IdP / OAuth ──
OAUTH_SERVER_URL=http://localhost:8080
OAUTH_CLIENT_ID=app1
OAUTH_CLIENT_SECRET=app1-secret
OAUTH_REDIRECT_URI=http://localhost:8011/callback

# 프론트엔드 (로그인 완료 후 사용자가 돌아갈 곳)
FRONTEND_URL=http://localhost:5181

# 백엔드 세션 secret — 다른 앱과 절대 같으면 안 됨
SESSION_SECRET=app1-backend-session-secret-change-me

# 백엔드 listen 포트
PORT=8011

# ── MariaDB (docker-compose 의 app1-mariadb) ──
# 호스트에서 직접 실행 시
DB_URL=jdbc:mariadb://localhost:3307/app1_notebook
# docker 안에서 띄울 때 (S-6 에서 사용)
# DB_URL=jdbc:mariadb://app1-mariadb:3306/app1_notebook
DB_USERNAME=app1
DB_PASSWORD=app1-dev
