# app2 (TaskBoard · Node + Vue, group-a) backend 환경 변수
# 사용: cp .env.example .env 후 값 채우기

# ── IdP / OAuth ──
OAUTH_SERVER_URL=http://localhost:8080
OAUTH_CLIENT_ID=app2
OAUTH_CLIENT_SECRET=app2-secret
OAUTH_REDIRECT_URI=http://localhost:8012/callback

# 프론트엔드
FRONTEND_URL=http://localhost:5182

# 백엔드 세션 secret — 다른 앱과 절대 같으면 안 됨
SESSION_SECRET=app2-backend-session-secret-change-me

# 백엔드 listen 포트
PORT=8012

# ── MongoDB (docker-compose 의 app2-mongo) ──
# 호스트에서 직접 실행 시
MONGO_URL=mongodb://app2:app2-dev@localhost:27018/app2_taskboard?authSource=admin
# docker 안에서 띄울 때 (S-6)
# MONGO_URL=mongodb://app2:app2-dev@app2-mongo:27017/app2_taskboard?authSource=admin
