# app2 (Node Express + Vue, group-a 멤버) backend 환경 변수
# 사용: cp .env.example .env 후 값 채우기

# IdP 서버 주소
OAUTH_SERVER_URL=http://localhost:8080

# OAuth client (server/store/clients.go 시드 참조)
OAUTH_CLIENT_ID=app2
OAUTH_CLIENT_SECRET=app2-secret

# 콜백 URL — IdP 의 redirect_uri 화이트리스트와 정확히 일치해야 함
OAUTH_REDIRECT_URI=http://localhost:8012/callback

# 프론트엔드
FRONTEND_URL=http://localhost:5182

# 백엔드 세션 secret — 다른 앱과 절대 같으면 안 됨
SESSION_SECRET=app2-backend-session-secret-change-me

# 백엔드 listen 포트
PORT=8012
