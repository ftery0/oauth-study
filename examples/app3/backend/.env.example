# app3 (HelpDesk · FastAPI + Next, group-b) backend 환경 변수
# 사용: cp .env.example .env 후 값 채우기

# ── IdP / OAuth ──
OAUTH_SERVER_URL=http://localhost:8080
OAUTH_CLIENT_ID=app3
OAUTH_CLIENT_SECRET=app3-secret
OAUTH_REDIRECT_URI=http://localhost:8013/callback

# 프론트엔드
FRONTEND_URL=http://localhost:5183

# 백엔드 세션 secret — 다른 앱과 절대 같으면 안 됨
SESSION_SECRET=app3-backend-session-secret-change-me

# 백엔드 listen 포트
PORT=8013

# ── PostgreSQL (docker-compose 의 app3-postgres) ──
# 호스트에서 직접 실행 시
DATABASE_URL=postgresql+asyncpg://app3:app3-dev@localhost:5434/app3_helpdesk
# docker 안에서 띄울 때 (S-6)
# DATABASE_URL=postgresql+asyncpg://app3:app3-dev@app3-postgres:5432/app3_helpdesk
